#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
#   HydraBot CLI
#   Commands: start | cli | update | config | status | logs | help
# ═══════════════════════════════════════════════════════════════

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# 保留使用者執行 hydrabot 時的目錄，供 main.py 作為專案工作區（與 Claude Code CLI 類似）
INVOCATION_PWD="$(pwd)"
cd "$SCRIPT_DIR"

# ── Colors ────────────────────────────────────────────────────
G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'
BOLD='\033[1m'; DIM='\033[2m'; R='\033[0;31m'; NC='\033[0m'
hr() { printf "${DIM}────────────────────────────────────────────────────${NC}\n"; }

# ── Python / venv ─────────────────────────────────────────────
activate_venv() {
    if [[ -f "$SCRIPT_DIR/venv/Scripts/activate" ]]; then
        source "$SCRIPT_DIR/venv/Scripts/activate"
    elif [[ -f "$SCRIPT_DIR/venv/bin/activate" ]]; then
        source "$SCRIPT_DIR/venv/bin/activate"
    fi
}

find_python() {
    # Prefer venv Python first (like Windows .bat does)
    if [[ -f "$SCRIPT_DIR/venv/Scripts/python" ]]; then
        echo "$SCRIPT_DIR/venv/Scripts/python"
        return
    elif [[ -f "$SCRIPT_DIR/venv/bin/python" ]]; then
        echo "$SCRIPT_DIR/venv/bin/python"
        return
    elif [[ -f "$SCRIPT_DIR/venv/bin/python3" ]]; then
        echo "$SCRIPT_DIR/venv/bin/python3"
        return
    fi

    # Fall back to system Python
    activate_venv
    for cmd in python3 python; do
        command -v "$cmd" &>/dev/null && { echo "$cmd"; return; }
    done
    echo ""
}

# ── Version ───────────────────────────────────────────────────
VER=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]') || VER="?"

# ── 無子命令時：有有效 TG/DC token → start，否則 → cli，無 config → help ──
if [[ -z "${1:-}" ]]; then
    _def="help"
    if [[ -f "$SCRIPT_DIR/config.json" ]]; then
        _py=$(find_python)
        if [[ -n "$_py" ]]; then
            if _out=$("$_py" -c "
import json, sys
try:
    d = json.load(open(sys.argv[1], encoding='utf-8'))
except Exception:
    sys.exit(1)
tg = (d.get('telegram_token') or '').strip()
dc = (d.get('discord_token') or '').strip()
ok = lambda t: bool(t) and 'YOUR_' not in t
print('start' if (ok(tg) or ok(dc)) else 'cli')
" "$SCRIPT_DIR/config.json" 2>/dev/null); then
                _line=$(printf '%s' "$_out" | tr -d '\r' | head -1)
                if [[ "$_line" == "start" || "$_line" == "cli" ]]; then
                    _def="$_line"
                fi
            fi
        fi
    fi
    set -- "$_def"
fi

# ── Commands ──────────────────────────────────────────────────
CMD="${1:-help}"

case "$CMD" in

# ── start ─────────────────────────────────────────────────────
start)
    printf "\n${C}${BOLD}🐍 HydraBot ${G}v${VER}${NC}\n"
    hr

    # Config check
    if [[ ! -f "$SCRIPT_DIR/config.json" ]]; then
        printf "${R}❌ 找不到 config.json！${NC}\n"
        printf "   请先运行安装: ${C}bash install.sh${NC}\n\n"
        exit 1
    fi

    # Check for placeholder values
    if grep -q "YOUR_TELEGRAM_BOT_TOKEN\|YOUR_MODEL_API_KEY" "$SCRIPT_DIR/config.json" 2>/dev/null; then
        printf "${Y}⚠  config.json 中仍有未填写的占位符！${NC}\n"
        printf "   运行 ${C}hydrabot config${NC} 编辑配置。\n\n"
        exit 1
    fi

    PYTHON=$(find_python)
    [[ -z "$PYTHON" ]] && { printf "${R}❌ 找不到 Python！${NC}\n"; exit 1; }

    mkdir -p "$SCRIPT_DIR/tools" "$SCRIPT_DIR/mcp_servers"

    # Auto-install dependencies if missing
    if ! "$PYTHON" -c "import openai, anthropic, telegram" &>/dev/null; then
        printf "  ${Y}正在安装依赖，请稍候...${NC}\n"
        "$PYTHON" -m pip install -r "$SCRIPT_DIR/requirements.txt" -q --disable-pip-version-check
        if [[ $? -ne 0 ]]; then
            printf "${R}❌ 依赖安装失败！请手动运行:${NC}\n"
            printf "  $PYTHON -m pip install -r requirements.txt\n\n"
            exit 1
        fi
        printf "  ${G}✓ 依赖已就绪${NC}\n\n"
    fi

    printf "  Python:  $($PYTHON --version)\n"
    printf "  安裝目錄: $SCRIPT_DIR\n"
    printf "  工作目錄: $INVOCATION_PWD\n\n"

    cd "$INVOCATION_PWD" 2>/dev/null || cd "$SCRIPT_DIR"
    exec "$PYTHON" "$SCRIPT_DIR/main.py" "${@:2}"
    ;;

# ── cli — 終端機互動（可不設 Telegram／Discord）────────────────
cli)
    if [[ ! -f "$SCRIPT_DIR/config.json" ]]; then
        printf "${R}❌ 找不到 config.json！${NC}\n"
        printf "   请先运行安装: ${C}bash install.sh${NC}\n\n"
        exit 1
    fi
    if grep -q "YOUR_MODEL_API_KEY\|YOUR_GOOGLE_AI_KEY" "$SCRIPT_DIR/config.json" 2>/dev/null; then
        printf "${Y}⚠  config.json 中模型仍有未填写的占位符！${NC}\n"
        printf "   运行 ${C}hydrabot config${NC} 编辑。\n\n"
        exit 1
    fi
    PYTHON=$(find_python)
    [[ -z "$PYTHON" ]] && { printf "${R}❌ 找不到 Python！${NC}\n"; exit 1; }
    mkdir -p "$SCRIPT_DIR/tools" "$SCRIPT_DIR/mcp_servers"
    if ! "$PYTHON" -c "import openai, anthropic" &>/dev/null; then
        printf "  ${Y}正在安装依赖，请稍候...${NC}\n"
        "$PYTHON" -m pip install -r "$SCRIPT_DIR/requirements.txt" -q --disable-pip-version-check
    fi
    printf "  ${C}HydraBot CLI 模式${NC}（工作目錄: ${INVOCATION_PWD}）\n\n"
    cd "$INVOCATION_PWD" 2>/dev/null || cd "$SCRIPT_DIR"
    EXTRA_FLAGS=""
    [[ "${2:-}" == "--dry-run" ]] && EXTRA_FLAGS="--dry-run"
    exec "$PYTHON" "$SCRIPT_DIR/main.py" --cli $EXTRA_FLAGS
    ;;

# ── run — 單次非互動執行 ──────────────────────────────────────
run)
    shift
    DRY=""
    PROMPT_ARGS=""
    for a in "$@"; do
        if [[ "$a" == "--dry-run" ]]; then
            DRY="--dry-run"
        else
            PROMPT_ARGS="$PROMPT_ARGS $a"
        fi
    done
    PROMPT_ARGS="${PROMPT_ARGS# }"
    if [[ -z "$PROMPT_ARGS" ]]; then
        printf "${R}❌ 請提供 prompt，例如: hydrabot run \"列出此專案結構\"${NC}\n"
        exit 1
    fi
    PYTHON=$(find_python)
    [[ -z "$PYTHON" ]] && { printf "${R}❌ 找不到 Python！${NC}\n"; exit 1; }
    cd "$INVOCATION_PWD" 2>/dev/null || cd "$SCRIPT_DIR"
    exec "$PYTHON" "$SCRIPT_DIR/main.py" --prompt "$PROMPT_ARGS" $DRY
    ;;

# ── update ────────────────────────────────────────────────────
update)
    bash "$SCRIPT_DIR/scripts/update.sh" "${2:-}"
    ;;

# ── config ────────────────────────────────────────────────────
config)
    if [[ ! -f "$SCRIPT_DIR/config.json" ]]; then
        printf "${R}❌ config.json 不存在，请先运行安装。${NC}\n"
        exit 1
    fi

    # Try to find an editor
    EDITOR_CMD="${EDITOR:-}"
    for ed in "$EDITOR_CMD" nano vim vi notepad; do
        command -v "$ed" &>/dev/null && { "$ed" "$SCRIPT_DIR/config.json"; exit 0; }
    done

    # Fallback: print path
    printf "${Y}找不到文本编辑器，请手动打开:${NC}\n"
    printf "  ${C}$SCRIPT_DIR/config.json${NC}\n\n"
    ;;

# ── status ────────────────────────────────────────────────────
status)
    printf "\n${C}${BOLD}🐍 HydraBot Status${NC}  ${DIM}v${VER}${NC}\n"
    hr

    # Config
    if [[ -f "$SCRIPT_DIR/config.json" ]]; then
        printf "  配置文件:   ${G}✓ 存在${NC}\n"

        PYTHON=$(find_python)
        if [[ -n "$PYTHON" ]]; then
            "$PYTHON" << 'PYEOF'
import json, sys, os
path = os.path.join(os.environ.get("SCRIPT_DIR", "."), "config.json")
try:
    c = json.loads(open(path).read())
    models = c.get("models", [])
    auth = c.get("authorized_users", [])
    print(f"  模型组数:   {len(models)} 组")
    for i, m in enumerate(models):
        print(f"    [{i}] {m.get('name','?')}  ({m.get('provider','?')} / {m.get('model','?')})")
    print(f"  授权用户:   {auth if auth else '（不限制）'}")
    tg = c.get("telegram_token","")
    masked = tg[:6]+"..."+tg[-4:] if len(tg)>10 else "???"
    print(f"  TG Token:   {masked}")
except Exception as e:
    print(f"  ⚠  读取失败: {e}")
PYEOF
        fi
    else
        printf "  配置文件:   ${R}✗ 不存在 (运行 bash install.sh)${NC}\n"
    fi

    # Tools
    TOOL_COUNT=$(ls "$SCRIPT_DIR/tools/"*.py 2>/dev/null | wc -l)
    printf "  自定义工具: ${C}${TOOL_COUNT} 个${NC}  (tools/)\n"

    # Memory
    if [[ -f "$SCRIPT_DIR/memory.json" ]]; then
        MEM_KEYS=$(python3 -c "import json; d=json.load(open('$SCRIPT_DIR/memory.json')); print(len(d))" 2>/dev/null || echo "?")
        printf "  记忆条目:   ${C}${MEM_KEYS} 条${NC}  (memory.json)\n"
    fi

    # venv
    [[ -d "$SCRIPT_DIR/venv" ]] \
        && printf "  虚拟环境:   ${G}✓ 存在${NC}\n" \
        || printf "  虚拟环境:   ${Y}⚠ 不存在 (运行 bash install.sh)${NC}\n"

    printf "\n"
    ;;

# ── logs ──────────────────────────────────────────────────────
logs)
    LOG="$SCRIPT_DIR/hydrabot.log"
    if [[ -f "$LOG" ]]; then
        tail -n "${2:-50}" "$LOG"
    else
        printf "${Y}暂无日志文件。${NC}\n"
        printf "  ${DIM}启动时将日志重定向: hydrabot start >> hydrabot.log 2>&1${NC}\n\n"
    fi
    ;;

# ── help / default ────────────────────────────────────────────
help|--help|-h|*)
    printf "\n${C}${BOLD}🐍 HydraBot CLI${NC}  ${DIM}v${VER}${NC}\n"
    hr
    printf "  ${BOLD}用法 / Usage:${NC}\n\n"
    printf "  ${C}hydrabot${NC}                無子命令：有有效 TG/DC token 則等同 start，否則等同 cli\n"
    printf "  ${C}hydrabot start${NC}          启动 Bot（在當前目錄作為專案工作區；可加 --workspace 路徑）\n"
    printf "  ${C}hydrabot cli${NC}            終端機互動（可不設 TG/DC；當前目錄為工作區）\n"
    printf "  ${C}hydrabot run \"…\"${NC}        單次非互動執行（跑完印結果就退出）\n"
    printf "  ${C}hydrabot update${NC}         更新到最新版本\n"
    printf "  ${C}hydrabot update --force${NC} 强制更新（即使版本相同）\n"
    printf "  ${C}hydrabot config${NC}         编辑 config.json\n"
    printf "  ${C}hydrabot status${NC}         查看安装状态与配置摘要\n"
    printf "  ${C}hydrabot logs [N]${NC}       查看最近 N 行日志（默认 50）\n"
    printf "  ${C}hydrabot help${NC}           显示此帮助\n\n"
    printf "  ${DIM}安装目录: $SCRIPT_DIR${NC}\n\n"
    ;;

esac
